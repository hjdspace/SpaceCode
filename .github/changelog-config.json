{
  "categories": [
    {
      "title": "### 💥 Breaking Changes（破坏性变更）",
      "labels": ["breaking-change", "Semver-Major"]
    },
    {
      "title": "### ✨ New Features（新功能）",
      "labels": ["feature", "enhancement", "Semver-Minor"]
    },
    {
      "title": "### 🐛 Bug Fixes（问题修复）",
      "labels": ["bug", "fix", "bugfix"]
    },
    {
      "title": "### ⚡ Performance（性能优化）",
      "labels": ["performance", "perf"]
    },
    {
      "title": "### 📝 Documentation（文档更新）",
      "labels": ["documentation", "docs"]
    },
    {
      "title": "### 📦 Dependencies（依赖更新）",
      "labels": ["dependencies"]
    },
    {
      "title": "### 🔧 Other Changes（其他变更）",
      "labels": ["*"]
    }
  ],
  "ignore_labels": ["ignore-for-release", "skip-changelog"],
  "sort": {
    "order": "ASC",
    "on_property": "commitDate"
  },
  "template": "#{{CHANGELOG}}\n\n**Full Changelog**: https://github.com/{{OWNER}}/{{REPOSITORY}}/compare/{{fromTag}}...{{toTag}}",
  "pr_template": "- #{{TITLE}} @#{{AUTHOR}}",
  "empty_template": "- 暂无变更",
  "label_extractor": [
    {
      "pattern": "^(feat|feature|新增|新功能)[：:]?(.*)",
      "target": "feature",
      "on_property": "title",
      "flags": "gu"
    },
    {
      "pattern": "^(fix|修复|修补)[：:]?(.*)",
      "target": "bug",
      "on_property": "title",
      "flags": "gu"
    },
    {
      "pattern": "^(perf|性能|优化)[：:]?(.*)",
      "target": "performance",
      "on_property": "title",
      "flags": "gu"
    },
    {
      "pattern": "^(docs|文档)[：:]?(.*)",
      "target": "documentation",
      "on_property": "title",
      "flags": "gu"
    },
    {
      "pattern": "^(chore\\(deps\\)|依赖)[：:]?(.*)",
      "target": "dependencies",
      "on_property": "title",
      "flags": "gu"
    },
    {
      "pattern": "^(refactor|重构)[：:]?(.*)",
      "target": "refactor",
      "on_property": "title",
      "flags": "gu"
    },
    {
      "pattern": "^BREAKING CHANGE[：:]?(.*)",
      "target": "breaking-change",
      "on_property": "body",
      "flags": "gu"
    }
  ],
  "max_tags_to_fetch": 200,
  "max_pull_requests": 200,
  "max_back_track_time_days": 365,
  "exclude_merge_branches": ["main", "master"],
  "commitMode": true
}
