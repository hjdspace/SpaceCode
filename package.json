{
  "name": "spacecode",
  "version": "0.3.2",
  "homepage": "https://github.com/hjdspace/SpaceCode",
  "author": {
    "name": "hjdspace",
    "email": "hjdspace1990@gmail.com"
  },
  "description": "SpaceCode - AI Agent Desktop Application (Electron + Vue 3)",
  "main": "dist-electron/main.js",
  "scripts": {
    "engine:install": "cd engine && bun install",
    "engine:build:desktop": "cd engine && bun run build-desktop.ts",
    "postinstall": "npm run engine:install",
    "copy-bun": "node scripts/copy-bun.cjs",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "npm run copy-bun && npm run engine:build:desktop && npm run build && electron-builder",
    "electron:build:win": "npm run copy-bun && npm run engine:build:desktop && npm run build && electron-builder --win",
    "electron:build:mac": "npm run copy-bun && npm run engine:build:desktop && npm run build && electron-builder --mac",
    "electron:build:linux": "npm run copy-bun && npm run engine:build:desktop && npm run build && electron-builder --linux",
    "typecheck": "vue-tsc --noEmit",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "changelog:all": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
    "version": "npm run changelog && git add CHANGELOG.md",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@mariozechner/pi-coding-agent": "^0.8.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.6",
    "diff": "^5.2.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "highlight.js": "^11.9.0",
    "lucide-vue-next": "^0.344.0",
    "marked": "^12.0.0",
    "node-pty": "^1.1.0",
    "openai": "^4.28.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/diff": "^5.0.9",
    "@types/express": "^5.0.6",
    "@vitejs/plugin-vue": "^5.0.4",
    "conventional-changelog-cli": "^5.0.0",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "sass": "^1.71.1",
    "sharp": "^0.34.5",
    "typescript": "^5.4.3",
    "vite": "^5.2.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "com.spacecode.desktop",
    "productName": "SpaceCode",
    "icon": "icons/icon-512.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/node-pty/**/*",
      "node_modules/@mariozechner/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*.node",
      "node_modules/@mariozechner/**/*"
    ],
    "extraResources": [
      {
        "from": "icons",
        "to": "icons",
        "filter": [
          "**/*.png",
          "**/*.ico",
          "**/*.icns"
        ]
      },
      {
        "from": "engine/bin",
        "to": "engine/bin"
      },
      {
        "from": "engine/dist-desktop",
        "to": "engine/dist-desktop"
      }
    ],
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerLanguages": [
        "zh-CN",
        "en-US"
      ],
      "language": "2052",
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "compression": "store"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  }
}
