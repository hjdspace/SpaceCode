{
  "name": "spacecode",
  "version": "0.6.9",
  "homepage": "https://github.com/hjdspace/SpaceCode",
  "author": {
    "name": "hjdspace",
    "email": "hjdspace1990@gmail.com"
  },
  "description": "SpaceCode - AI Agent Desktop Application (Electron + Vue 3)",
  "main": "dist-electron/main.js",
  "scripts": {
    "engine:install": "cd engine && bun install",
    "engine:build:desktop": "cd engine && bun run build-desktop.ts",
    "postinstall": "node scripts/patch-node-pty.cjs && npm run engine:install",
    "copy-bun": "node scripts/copy-bun.cjs",
    "copy-mcp-vendor": "node scripts/copy-mcp-vendor.cjs",
    "download:officecli": "node scripts/download-officecli.mjs",
    "dev": "vite",
    "prebuild": "node scripts/clean-dist-electron.cjs",
    "build": "vue-tsc --noEmit && vite build",
    "check:performance": "node scripts/check-build-performance.cjs",
    "build:proxy": "node -e \"const esbuild=require('esbuild');esbuild.buildSync({entryPoints:['electron/proxy/index.ts'],bundle:true,outdir:'dist-electron/proxy',platform:'node',format:'cjs',external:['electron']})\"",
    "build:all": "npm run build && npm run build:proxy",
    "preview": "vite preview",
    "electron:dev": "vite",
    "icons:generate": "node icons/generate-icons.cjs && node icons/generate-ico.cjs",
    "icons:generate:ico": "node icons/generate-ico.cjs",
    "electron:build": "npm run icons:generate && npm run copy-bun && npm run copy-mcp-vendor && npm run prebuild:cua-driver && npm run engine:build:desktop && npm run build:all && electron-builder",
    "electron:build:win": "npm run icons:generate && npm run copy-bun && npm run copy-mcp-vendor && npm run prebuild:cua-driver && npm run engine:build:desktop && npm run build:all && electron-builder --win",
    "electron:build:mac": "npm run icons:generate && npm run copy-bun && npm run copy-mcp-vendor && npm run prebuild:cua-driver && npm run engine:build:desktop && npm run build:all && electron-builder --mac",
    "electron:build:linux": "npm run icons:generate && npm run copy-bun && npm run copy-mcp-vendor && npm run prebuild:cua-driver && npm run engine:build:desktop && npm run build:all && electron-builder --linux",
    "electron:build:local": "node scripts/electron-build-local.cjs",
    "electron:build:win:local": "node scripts/electron-build-local.cjs --win",
    "electron:build:mac:local": "node scripts/electron-build-local.cjs --mac",
    "electron:build:linux:local": "node scripts/electron-build-local.cjs --linux",
    "prebuild:cua-driver": "node scripts/download-cua-driver.mjs",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:electron": "node --experimental-strip-types --test tests/electron/*.test.ts",
    "test:electron:ci": "node --experimental-strip-types --test --test-reporter=spec tests/electron/*.test.ts",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "changelog:all": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
    "version": "npm run changelog && git add CHANGELOG.md",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@git-diff-view/file": "^0.1.3",
    "@git-diff-view/vue": "^0.1.3",
    "@mariozechner/pi-coding-agent": "^0.73.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.6",
    "diff": "^5.2.0",
    "dompurify": "^3.4.11",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "fuse.js": "^7.3.0",
    "glob": "^13.0.6",
    "highlight.js": "^11.9.0",
    "lucide-vue-next": "^0.344.0",
    "marked": "^12.0.0",
    "mermaid": "^11.15.0",
    "node-pty": "^1.1.0",
    "openai": "^4.28.0",
    "pinia": "^2.1.7",
    "prism-react-renderer": "^2.4.1",
    "qrcode": "^1.5.4",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/cors": "^2.8.19",
    "@types/diff": "^5.0.9",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "conventional-changelog-cli": "^5.0.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.0",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "sass": "^1.71.1",
    "sass-embedded": "^1.100.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3",
    "typescript": "^5.4.3",
    "vite": "^8.1.4",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "com.spacecode.desktop",
    "productName": "SpaceCode",
    "icon": "icons",
    "publish": {
      "provider": "github",
      "owner": "hjdspace",
      "repo": "SpaceCode"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/node-pty/**/*",
      "node_modules/@mariozechner/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "node_modules/@mariozechner/**/*",
      "dist-electron/proxy/**/*"
    ],
    "extraResources": [
      {
        "from": "icons",
        "to": "icons",
        "filter": [
          "*.png",
          "*.ico",
          "*.icns"
        ]
      },
      {
        "from": "engine/bin",
        "to": "engine/bin"
      },
      {
        "from": "engine/dist-desktop",
        "to": "engine/dist-desktop"
      },
      {
        "from": "skills-lib",
        "to": "skills-lib"
      },
      {
        "from": "agents-lib",
        "to": "agents-lib"
      },
      {
        "from": "release-notes",
        "to": "release-notes"
      },
      {
        "from": "resources/builtin-hooks",
        "to": "builtin-hooks"
      },
      {
        "from": "mcp-vendor",
        "to": "mcp-vendor"
      },
      {
        "from": "resources/officecli",
        "to": "officecli",
        "filter": [
          "**/*",
          "!README.md",
          "!**/*.update.partial",
          "!**/*.old",
          "!**/*.tmp"
        ]
      },
      {
        "from": "resources/cua-driver",
        "to": "cua-driver",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "design-systems-lib",
        "to": "design-systems-lib"
      }
    ],
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerLanguages": [
        "zh-CN",
        "en-US"
      ],
      "language": "2052",
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "compression": "store"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  }
}
